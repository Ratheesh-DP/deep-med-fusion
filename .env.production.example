# Frontend on Vercel
VITE_API_BASE_URL=https://deep-med-fusion-api.onrender.com
VITE_AI_SPACE_URL=https://huggingface.co/spaces/Ratheesh-DP/deep-med-fusion

# Backend on Render
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST.neon.tech/deepmedfusion?sslmode=require
API_CORS_ORIGINS=https://deep-med-fusion.vercel.app,http://localhost:5173
MODEL_DEVICE=cpu

# Cloudinary for demo image/result storage
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
CLOUDINARY_UPLOAD_FOLDER=deep-med-fusion

# S3-compatible storage fallback. Leave blank if using Cloudinary for demos.
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=medical-imaging
