{
  "family": "deep-med-fusion-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "REPLACE_WITH_ECR_IMAGE",
      "essential": true,
      "portMappings": [{ "containerPort": 8000, "protocol": "tcp" }],
      "environment": [
        { "name": "MODEL_DEVICE", "value": "cpu" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "REPLACE_WITH_SECRET_ARN" }
      ]
    }
  ]
}
